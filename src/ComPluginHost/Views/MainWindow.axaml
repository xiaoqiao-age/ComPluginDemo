<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ComPluginHost.ViewModels"
        x:Class="ComPluginHost.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="COM Plugin Host - Reg-Free COM (SxS Manifest)"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Margin="10" RowDefinitions="Auto,*,Auto,Auto">

        <!-- 顶部：添加插件区域 -->
        <Border Grid.Row="0" BorderBrush="#DDDDDD" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,0,0,10"
                Background="#F8F8F8">
            <Grid RowDefinitions="Auto,6,Auto" ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="ProgID:"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewProgId}"
                         Watermark="例如 ComPluginDemo.Calculator"
                         Margin="0,0,8,0"/>
                <Button Grid.Row="0" Grid.Column="2" Content="添加插件"
                        Command="{Binding AddPluginCommand}"
                        Margin="0,0,8,0"/>
                <Button Grid.Row="0" Grid.Column="3" Content="重新加载全部"
                        Command="{Binding LoadAllPluginsCommand}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Manifest:"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           FontSize="12" Foreground="#888"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                         Text="{Binding NewManifestPath}"
                         Watermark="可选, 组件清单相对路径 (如 CSharpComPlugin\CSharpComPlugin.manifest)"
                         FontSize="12"/>
            </Grid>
        </Border>

        <!-- 中间：左右分栏 -->
        <Grid Grid.Row="1" ColumnDefinitions="220,10,*">

            <!-- 左侧：插件列表 -->
            <Border Grid.Column="0" BorderBrush="#DDDDDD" BorderThickness="1"
                    CornerRadius="4">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="已加载插件" FontWeight="Bold"
                               Margin="10,8" FontSize="14"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Plugins}"
                             SelectedItem="{Binding SelectedPlugin}"
                             Margin="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ProgId}"
                                               FontSize="11" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Content="移除选中插件"
                            Command="{Binding RemovePluginCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="8,4,8,8"/>
                </Grid>
            </Border>

            <!-- 右侧：插件交互区 -->
            <Border Grid.Column="2" BorderBrush="#DDDDDD" BorderThickness="1"
                    CornerRadius="4" Padding="12">
                <Grid RowDefinitions="Auto,10,Auto,10,*">

                    <!-- 插件详情 -->
                    <Border Grid.Row="0" Background="#F0F4FF" CornerRadius="4"
                            Padding="12" MinHeight="80">
                        <TextBlock Text="{Binding PluginDetailText}"
                                   TextWrapping="Wrap" LineHeight="22"/>
                    </Border>

                    <!-- 输入区域 -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding InputText}"
                                 Watermark="输入内容..."
                                 Margin="0,0,8,0"
                                 IsEnabled="{Binding HasSelectedPlugin}"/>
                        <Button Grid.Column="1" Content="执行"
                                Command="{Binding ExecuteCommand}"
                                MinWidth="80"
                                FontWeight="SemiBold"/>
                    </Grid>

                    <!-- 输出区域 -->
                    <Grid Grid.Row="4" RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="输出结果:" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBox Grid.Row="1"
                                 Text="{Binding OutputText}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="#FAFAFA"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 日志区域 -->
        <Expander Grid.Row="2" Header="日志" Margin="0,10,0,0"
                  IsExpanded="False">
            <TextBox Text="{Binding LogText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="120"
                     FontSize="12"
                     FontFamily="Consolas"
                     Background="#F5F5F5"/>
        </Expander>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Background="#F0F0F0" CornerRadius="4"
                Padding="10,6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#666"/>
        </Border>
    </Grid>
</Window>
